# Application Settings
APP_NAME=Cryptanium
APP_ENV=development
HOST=0.0.0.0
PORT=8000

# Database Configuration (SQLite default for local, PostgreSQL for production)
DATABASE_URL=sqlite:///./cryptanium.db

# JWT Security
SECRET_KEY=cryptanium-super-secret-key-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# GitHub OAuth Integration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# OpenRouter / LLM Configuration
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-4-340b-instruct
