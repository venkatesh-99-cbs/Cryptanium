# Application Settings
APP_NAME=Cryptanium
APP_ENV=development
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:5173

# Local Docker/testing uses SQLite. For Neon, replace with your pooled SSL URL.
DATABASE_URL=sqlite:///./cryptanium.db
# DATABASE_URL=postgresql://user:password@ep-example.neon.tech/neondb?sslmode=require

# JWT Security
SECRET_KEY=generate-a-long-random-secret-before-starting
# POSTGRES_PASSWORD=only-needed-with: docker compose --profile postgres up
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# GitHub OAuth Integration
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# OpenRouter / LLM Configuration
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-4-340b-instruct
SCANNER_MAX_CONCURRENCY=2
